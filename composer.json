{
    "name": "hexlet/code",
    "description": "A PHP-based diff generator for files",
    "license": "MIT",
    "bin": ["bin/gendiff"],
    "autoload": {
        "psr-4": {
            "Hexlet\\Code\\": "src/"
        },
        "files": [
            "src/genDiff.php"
        ]
    },
    "require": {
        "docopt/docopt": "^1.0",
        "symfony/yaml": "^7.4",
        "funct/funct": "^1.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0"
    }
}
